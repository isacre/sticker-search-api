APP_NAME=sticker-search-api
DEBUG=false
API_PREFIX=/api/v1
# STICKERS_DIR=/caminho/para/stickers

# Postgres + pgvector (docker compose na raiz do repo)
DATABASE_URL=postgresql://sticker:sticker@localhost:5433/sticker_search
CLIP_IMAGE_MODEL_NAME=clip-ViT-B-32
CLIP_TEXT_MODEL_NAME=clip-ViT-B-32-multilingual-v1
INDEX_BATCH_SIZE=32

# Busca híbrida: CLIP (recall + rerank) + tags + RRF
SEARCH_MIN_SCORE=0.25
SEARCH_RECALL_SIZE=200
SEARCH_RETURN_SIZE=60
SEARCH_HNSW_EF_SEARCH=1000
SEARCH_HYBRID_RRF_K=60

# Filtro +18: oculta stickers com nsfw_score >= NSFW_MAX_SCORE
NSFW_FILTER_ENABLED=true
NSFW_MAX_SCORE=0.6
NSFW_MODEL_NAME=Falconsai/nsfw_image_detection
NSFW_BATCH_SIZE=16

# LLM vision para gerar tags PT/EN (OpenAI-compatible)
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_CONCURRENCY=3
# LLM_MAX_RETRIES=6
# LLM_RETRY_BASE_DELAY=2.0
# LLM_MIN_REQUEST_INTERVAL=0.15
# LLM_IMAGE_MAX_SIZE=512
# LLM_IMAGE_DETAIL=low
